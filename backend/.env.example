# ==================== BASE DE DONNÉES ====================
DB_NAME=hestim_planner
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_DIALECT=mysql

# ==================== SERVEUR ====================
PORT=5000
NODE_ENV=development

# Origines autorisées pour CORS (séparées par des virgules)
# En production : mettre l'URL réelle du frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== JWT ====================
# OBLIGATOIRE — Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_VALEUR_ALEATOIRE_LONGUE
JWT_EXPIRES_IN=7d

# ==================== EMAIL (Gmail App Password) ====================
EMAIL_SERVICE=smtp
EMAIL_FROM="HESTIM Planner <votre-email@gmail.com>"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
# Générer un mot de passe d'application Gmail : myaccount.google.com/apppasswords
SMTP_PASSWORD=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
