{
  "name": "hestim-planner",
  "version": "1.0.0",
  "description": "HESTIM Planner — Système de planification des emplois du temps (Projet PACTE)",
  "private": true,
  "scripts": {
    "start":       "bash start.sh",
    "dev":         "bash start.sh --dev",
    "start:prod":  "bash start.sh --no-seed",
    "dev:prod":    "bash start.sh --dev --no-seed",

    "backend":     "cd backend && node server.js",
    "backend:dev": "cd backend && npx nodemon server.js",
    "frontend":    "cd frontend && npm run dev",
    "seed":        "cd backend && node seed.js",

    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build":       "npm run build --prefix frontend"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
